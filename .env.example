# LLM 接入配置（复制本文件为 .env 并填入真实值）
# .env 不会被 git 跟踪，可安全存放密钥

# LLM 服务的 API key（你的 OpenAI 兼容网关或服务方提供）
LLM_API_KEY=your_api_key_here

# 网关地址（OpenAI 兼容格式）
LLM_BASE_URL=https://your-llm-gateway.example.com/v1

# 模型 / endpoint 名称
LLM_MODEL=your-model-name

# playwright 抓取后端的 chrome.exe 路径（仅 fetch_backend=playwright 时需要）
# 本机路径含用户名，放 .env 不入库；留空则用 config.yaml 的 chrome_path
CHROME_PATH=
